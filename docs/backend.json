
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores user-specific settings and overall progress for the application, designed for local persistence.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity. (Primary Key)"
        },
        "preferredLanguage": {
          "type": "string",
          "description": "The user's preferred language for the application interface."
        },
        "overallProgressPercentage": {
          "type": "number",
          "description": "A calculated percentage (0-100) representing the user's overall progress."
        }
      },
      "required": [
        "id",
        "preferredLanguage",
        "overallProgressPercentage"
      ]
    },
    "FormSubmission": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "FormSubmission",
      "type": "object",
      "description": "Captured form data for triggering document generation or tracking user requests in the cloud.",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Reference to the authenticated user who made the submission."
        },
        "name": {
          "type": "string",
          "description": "Name provided in the form."
        },
        "requestType": {
          "type": "string",
          "description": "The type of document or help requested (e.g., 'NIE', 'Padron')."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the submission."
        }
      },
      "required": [
        "userId",
        "name",
        "requestType"
      ]
    },
    "Procedure": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Procedure",
      "type": "object",
      "description": "Represents a main legal or administrative process immigrants need to follow in Spain.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "countrySpecificName": { "type": "string" },
        "category": { "type": "string" },
        "isEnabled": { "type": "boolean" }
      },
      "required": ["id", "name", "description", "countrySpecificName", "category", "isEnabled"]
    },
    "Step": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Step",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "procedureId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "procedureId", "title", "description", "order"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/procedures/{procedureId}",
        "definition": {
          "entityName": "Procedure",
          "schema": { "$ref": "#/backend/entities/Procedure" },
          "description": "Public, read-only administrative procedures."
        }
      },
      {
        "path": "/formSubmissions/{submissionId}",
        "definition": {
          "entityName": "FormSubmission",
          "schema": { "$ref": "#/backend/entities/FormSubmission" },
          "description": "User-submitted data for document generation workflows."
        }
      }
    ]
  }
}
