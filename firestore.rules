
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Public content
    match /procedures/{procedureId} {
      allow read: if true;
      allow write: if false;
      
      match /steps/{stepId} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /documentRequirements/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /externalResources/{resId} {
      allow read: if true;
      allow write: if false;
    }

    match /officialFormLinks/{linkId} {
      allow read: if true;
      allow write: if false;
    }

    // User submissions: Allow creation only if authenticated and data matches UID
    match /formSubmissions/{submissionId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list, update, delete: if false;
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
